NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Maps ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Admin auth (used by /api/auth/admin-login) ───────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── AI Planner ───────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
NEXT_PUBLIC_AI_PLANNER_ENABLED=false

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=National Park Quest <noreply@trailstory.app>

# ── Payment (Omise — https://omise.co) ────────────────────────────────────────
# PAYMENT_PROVIDER=omise  # set to 'omise' to enable real payments (default: mock)
OMISE_PUBLIC_KEY=         # pkey_... (used client-side with omise.js)
OMISE_SECRET_KEY=         # skey_... (server-side only — never expose to client)
OMISE_WEBHOOK_SECRET=     # from Omise Dashboard → Webhooks

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
